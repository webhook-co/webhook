# Dependencies
node_modules/

# Build output
dist/
build/
.turbo/
.wrangler/
.next/
.open-next/
out/
*.tsbuildinfo

# Per-environment wrangler deploy overlays: generated at deploy from the committed
# wrangler.jsonc + out-of-band ids/secret refs. Real ids never get committed (no-secrets).
wrangler.prod.jsonc
wrangler.*.prod.jsonc

# Next.js auto-generates this and flip-flops it between build/dev type paths.
# It lives under the already-ignored .next/ and is regenerated by `next dev`/`next build`.
next-env.d.ts

# Environment
.env
.env.*
# wrangler / OpenNext local dev secrets (next dev + `opennextjs-cloudflare preview`)
.dev.vars
.dev.vars.*
**/.dev.vars
**/.dev.vars.*

# Logs
*.log

# Test coverage
coverage/

# Playwright + Lighthouse-CI output
test-results/
playwright-report/
.last-run.json
.lighthouseci/

# macOS
.DS_Store

# Scratch / temp files
.tmp-*

# Cursor plan files (local working artifacts, not committed; the rest of .cursor/ stays tracked)
.cursor/plans/
