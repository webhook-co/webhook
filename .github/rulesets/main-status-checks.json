{
  "name": "main — status checks & history (no bypass)",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["~DEFAULT_BRANCH"],
      "exclude": []
    }
  },
  "bypass_actors": [],
  "rules": [
    { "type": "deletion" },
    { "type": "non_fast_forward" },
    { "type": "required_linear_history" },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "install" },
          { "context": "lint" },
          { "context": "format-check" },
          { "context": "typecheck" },
          { "context": "test" },
          { "context": "build" },
          { "context": "no-skipped-tests" },
          { "context": "tsconfig-boundary" },
          { "context": "codeql" },
          { "context": "gitleaks" }
        ]
      }
    }
  ]
}
