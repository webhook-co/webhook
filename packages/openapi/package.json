{
  "name": "@webhook-co/openapi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./routes": "./src/routes.ts",
    "./openapi.json": "./src/openapi.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "generate": "WEBHOOK_OPENAPI_WRITE=1 vitest run src/generate.test.ts",
    "validate": "redocly lint src/openapi.json",
    "test": "vitest run --coverage && pnpm run validate"
  },
  "dependencies": {
    "@webhook-co/contract": "workspace:*",
    "@webhook-co/shared": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@redocly/cli": "^2.5.0"
  }
}
