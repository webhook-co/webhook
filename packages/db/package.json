{
  "name": "@webhook-co/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./api-keys": "./src/api-keys.ts",
    "./grants": "./src/grants.ts",
    "./credential": "./src/credential.ts",
    "./credential-resolver": "./src/credential-resolver.ts",
    "./auth-audit": "./src/auth-audit.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "migrate:up": "dbmate up",
    "migrate:down": "dbmate down",
    "migrate:status": "dbmate status"
  },
  "dependencies": {
    "@webhook-co/contract": "workspace:*",
    "@webhook-co/shared": "workspace:*",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  }
}
