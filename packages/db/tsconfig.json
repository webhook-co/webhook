{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    // Node<->Workers tsconfig boundary (see engineering-conventions rule). db is the
    // Node/Postgres package (types: ["node"]) with no DOM/WebCrypto lib; its internal deps
    // (contract, shared, + webhooks-spec reached transitively via shared's `export *`) are
    // all Workers-typed. Resolving them to source would make tsc re-typecheck their
    // WebCrypto code (crypto.subtle.*) under node libs, where @types/node's
    // Uint8Array<ArrayBufferLike> doesn't satisfy the DOM BufferSource. Every internal dep
    // crosses the boundary, so we redirect the whole `@webhook-co/*` scope to the emitted
    // declarations — built before this package (turbo `^build`) and validated once in their
    // own (workers-types) configs. The wildcard is self-maintaining: it covers transitive
    // reach and any future internal dep without re-listing the closure by hand.
    "paths": {
      "@webhook-co/*": ["../*/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", ".turbo", "src/**/*.test.ts", "test/**/*.ts"]
}
