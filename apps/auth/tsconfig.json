{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    // App, not a published library: no .d.ts emit. Avoids declaration-portability
    // errors from third-party (zod/better-auth) inferred types on the exported config.
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
