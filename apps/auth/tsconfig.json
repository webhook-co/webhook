{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // The Next-on-OpenNext app (DOM/Workers world). `src/auth.ts` is the NODE-context schema generator
  // (uses pg + process.env); it is typechecked separately under tsconfig.gen.json — excluded here so
  // the DOM lib set doesn't fail on node built-ins.
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    ".turbo",
    "src/auth.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
