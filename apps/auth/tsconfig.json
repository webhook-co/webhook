{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      // db + shared are Node/Workers-typed (node:crypto / WebCrypto over Uint8Array). This is a DOM-lib
      // Next app, so consume their BUILT output, not source: tsc resolves the extensionless target to
      // index.d.ts (clean types — no re-checking their crypto under DOM lib) and turbopack resolves it to
      // index.js (real runtime). turbo builds them first (^build). See ADR-0027 / the tsconfig boundary.
      "@webhook-co/db": ["../../packages/db/dist/index"],
      "@webhook-co/shared": ["../../packages/shared/dist/index"],
      "@webhook-co/contract": ["../../packages/contract/dist/index"],
      "@webhook-co/webhooks-spec": ["../../packages/webhooks-spec/dist/index"]
    }
  },
  // The Next-on-OpenNext app (DOM/Workers world). `src/auth.ts` is the NODE-context schema generator
  // (uses pg + process.env); it is typechecked separately under tsconfig.gen.json — excluded here so
  // the DOM lib set doesn't fail on node built-ins.
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    ".turbo",
    "src/auth.ts",
    // The Worker entry imports the generated `.open-next/worker.js` (absent at typecheck); it's
    // verified by build:cf/deploy:dry, and its config lives in the (type-checked) ./issuer/oauth-config.
    "src/worker.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
