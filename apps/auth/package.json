{
  "name": "@webhook-co/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:dry": "opennextjs-cloudflare build && wrangler deploy --dry-run",
    "start": "next start",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.gen.json",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config src/auth.ts --yes --output ../../packages/db/db/migrations/.better-auth.schema.sql"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.19",
    "@webhook-co/shared": "workspace:*",
    "@webhook-co/ui": "workspace:*",
    "better-auth": "^1.6.19",
    "geist": "^1.7.2",
    "lucide-react": "^1.20.0",
    "motion": "^12.40.0",
    "next": "^16.2.9",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1"
  }
}
