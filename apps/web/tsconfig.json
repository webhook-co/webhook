{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      // tsconfig-boundary: type-check @webhook-co/shared's WebCrypto helpers against their built .d.ts,
      // not source — recompiling their `crypto.subtle.sign(...)` under this app's DOM lib fails (the node
      // Uint8Array<ArrayBufferLike> vs DOM BufferSource clash). Runtime (Next/Turbopack + vitest) still
      // resolves the src via the package exports map; turbo builds shared first, so the .d.ts is current.
      // (db's modules already cast around this, so they need no redirect.)
      "@webhook-co/shared/audit": ["../../packages/shared/dist/audit.d.ts"],
      "@webhook-co/shared/bytes": ["../../packages/shared/dist/bytes.d.ts"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist", ".turbo", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
